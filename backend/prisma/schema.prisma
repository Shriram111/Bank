generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  phone           String    @unique
  password        String
  name            String
  avatar          String?
  role            Role      @default(CUSTOMER)
  isVerified      Boolean   @default(false)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  cards           Card[]
  loans           Loan[]
  investments     Investment[]
  notifications   Notification[]
  transactions    Transaction[]
  beneficiaries   Beneficiary[]
  rewards         Reward[]
  auditLogs       AuditLog[]
  supportTickets  SupportTicket[]
  sessions        Session[]

  @@map("users")
}

model Session {
  id              String    @id @default(uuid())
  userId          String
  refreshToken    String    @unique
  ipAddress       String?
  userAgent       String?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id              String    @id @default(uuid())
  userId          String
  accountNumber   String    @unique
  accountType     AccountType
  bankName        String    @default("NeoBank Cloud")
  ifscCode        String    @default("NEOB0000001")
  balance         Float     @default(0)
  currency        String    @default("INR")
  status          AccountStatus @default(ACTIVE)
  interestRate    Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@map("accounts")
}

model Transaction {
  id              String    @id @default(uuid())
  accountId       String
  type            TransactionType
  category        String?
  description     String
  amount          Float
  balanceAfter    Float
  status          TransactionStatus @default(COMPLETED)
  reference       String    @unique
  recipientName   String?
  recipientAccount String?
  recipientIfsc   String?
  upiId           String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sender          User?     @relation(fields: [senderId], references: [id])
  senderId        String?

  @@map("transactions")
}

model Card {
  id              String    @id @default(uuid())
  userId          String
  cardNumber      String
  cardType        CardType
  cardHolderName  String
  expiryMonth     Int
  expiryYear      Int
  cvv             String
  pin             String?
  limit           Float     @default(500000)
  spent           Float     @default(0)
  status          CardStatus @default(ACTIVE)
  isLocked        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cards")
}

model Loan {
  id              String    @id @default(uuid())
  userId          String
  loanType        LoanType
  principalAmount Float
  interestRate    Float
  tenure          Int
  emiAmount       Float
  outstandingAmount Float
  paidAmount      Float     @default(0)
  startDate       DateTime
  endDate         DateTime
  status          LoanStatus @default(ACTIVE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loans")
}

model Investment {
  id              String    @id @default(uuid())
  userId          String
  type            InvestmentType
  name            String
  units           Float
  navPerUnit      Float
  investedAmount  Float
  currentValue    Float
  returns         Float     @default(0)
  returnsPercent  Float     @default(0)
  status          InvestmentStatus @default(ACTIVE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investments")
}

model Beneficiary {
  id              String    @id @default(uuid())
  userId          String
  name            String
  accountNumber   String
  ifscCode        String
  bankName        String
  accountType     String    @default("savings")
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("beneficiaries")
}

model Notification {
  id              String    @id @default(uuid())
  userId          String
  title           String
  message         String
  type            NotificationType @default(GENERAL)
  isRead          Boolean   @default(false)
  metadata        Json?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Reward {
  id              String    @id @default(uuid())
  userId          String
  points          Int
  type            RewardType
  description     String
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rewards")
}

model AuditLog {
  id              String    @id @default(uuid())
  userId          String
  action          String
  resource        String
  resourceId      String?
  oldValues       Json?
  newValues       Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model SupportTicket {
  id              String    @id @default(uuid())
  userId          String
  subject         String
  description     String
  category        String
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus @default(OPEN)
  assignedTo      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

enum Role {
  CUSTOMER
  ADMIN
  SUPPORT
  SUPER_ADMIN
}

enum AccountType {
  SAVINGS
  CURRENT
  FIXED_DEPOSIT
  RECURRING_DEPOSIT
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  FROZEN
  CLOSED
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER
  UPI
  BILL_PAYMENT
  RECHARGE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum CardType {
  DEBIT
  CREDIT
  PREPAID
}

enum CardStatus {
  ACTIVE
  BLOCKED
  EXPIRED
  LOST
}

enum LoanType {
  PERSONAL
  HOME
  CAR
  EDUCATION
  BUSINESS
}

enum LoanStatus {
  ACTIVE
  CLOSED
  DEFAULTED
  PREPAYMENT
}

enum InvestmentType {
  MUTUAL_FUND
  STOCK
  GOLD
  FIXED_DEPOSIT
  BOND
}

enum InvestmentStatus {
  ACTIVE
  MATURED
  REDEEMED
}

enum NotificationType {
  GENERAL
  TRANSACTION
  SECURITY
  PROMOTIONAL
  SYSTEM
}

enum RewardType {
  EARNED
  REDEEMED
  EXPIRED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
